<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.MaterialComponents.Light.NoActionBar">
        <!-- Customize your theme here. -->
        <item name="colorPrimary">@color/bamboo_primary</item>
        <item name="colorPrimaryDark">@color/bamboo_dark</item>
        <item name="colorAccent">@color/bamboo_gold</item>
        <item name="android:windowBackground">@color/bamboo_bg</item>
        <item name="android:statusBarColor">@color/bamboo_dark</item>
    </style>

    <style name="AppTheme.NoActionBar" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="colorPrimary">@color/bamboo_primary</item>
        <item name="colorAccent">@color/bamboo_gold</item>
    </style>


    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <item name="android:background">@drawable/splash</item>
    </style>

    <style name="Theme.App.Splash" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowBackground">@drawable/splash_background</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:statusBarColor">#0D3B2E</item>
        <item name="android:navigationBarColor">#0D3B2E</item>
    </style>

    <style name="CircleImage">
        <item name="cornerSize">50%</item>
    </style>
</resources>