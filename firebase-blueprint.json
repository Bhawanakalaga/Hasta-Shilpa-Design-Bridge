{
  "entities": {
    "User": {
      "title": "User",
      "description": "Artisan user profile",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "language": { "type": "string" },
        "phone": { "type": "string" },
        "favorites": { "type": "array", "items": { "type": "string" } },
        "cart": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "language"]
    },
    "Product": {
      "title": "Product",
      "description": "Bamboo/Cane design products",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "object" },
        "description": { "type": "object" },
        "image": { "type": "string" },
        "price": { "type": "number" },
        "costPrice": { "type": "number" },
        "category": { "type": "string" },
        "measurements": { "type": "string" },
        "materials": { "type": "array" },
        "tools": { "type": "array" },
        "steps": { "type": "array" },
        "timeRequired": { "type": "string" },
        "sellerId": { "type": "string" },
        "isModern": { "type": "boolean" }
      },
      "required": ["title", "description", "price", "image"]
    },
    "MaterialTracker": {
      "title": "MaterialTracker",
      "description": "Tracking bamboo/cane usage",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "productId": { "type": "string" },
        "bambooCount": { "type": "number" },
        "cost": { "type": "number" },
        "date": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "bambooCount", "cost"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Available designs and marketplace listings"
    },
    "/material_tracking/{trackId}": {
      "schema": "MaterialTracker",
      "description": "Usage logs for artisans"
    }
  }
}
